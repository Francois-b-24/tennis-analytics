# Racine du projet (chemins relatifs résolus depuis ce dossier)
ROOT_PATH=

# Fichier DuckDB optionnel ; si vide, connexion en mémoire + vues sur parquet
DUCKDB_PATH=

# Seuil d'alerte CI / ingestion : taille max d'un parquet (octets), défaut 100_000_000
MAX_PARQUET_BYTES=

# Optionnel : token Codecov pour badge de couverture
CODECOV_TOKEN=

# Optionnel : webhook Slack pour notifier les échecs d'ingestion
SLACK_WEBHOOK_URL=
